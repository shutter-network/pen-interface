# WalletConnect Cloud project ID if you want to use it
VITE_WALLETCONNECT_PROJECT_ID=

# RPC endpoints — use Alchemy / Infura / your own node
# Required for eth_getLogs (cumulative disbursements); public RPCs cap block ranges too tightly
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/<api-key>
# Infura:  https://sepolia.infura.io/v3/<api-key>
VITE_RPC_SEPOLIA=
VITE_RPC_MAINNET=

# Contract addresses — Sepolia
VITE_SEPOLIA_SEAT_TOKEN=0x0cC04c4F133A796F894B9Cb0Cc14b93D559c5488
VITE_SEPOLIA_BONDING_TRANCHE=0x070518E29C6523a05cF3A3E0F9cEE13e593c9F3c
VITE_SEPOLIA_PRINCIPAL_MANAGER=0x199ce359dc4Fa0fd2300F11294B27024F7cb55eF
VITE_SEPOLIA_PRINCIPAL_MANAGER_DEPLOY_BLOCK=11022056
# Governing Safe multisig — optional, shown for reference on the Links tab
VITE_SEPOLIA_SAFE=

# Contract addresses — Mainnet (leave empty until deployed)
VITE_MAINNET_SEAT_TOKEN=
VITE_MAINNET_BONDING_TRANCHE=
VITE_MAINNET_PRINCIPAL_MANAGER=
VITE_MAINNET_PRINCIPAL_MANAGER_DEPLOY_BLOCK=
VITE_MAINNET_SAFE=

# Block explorer base URLs — used for transaction links (no trailing slash)
VITE_SEPOLIA_EXPLORER_URL=https://sepolia.etherscan.io
VITE_MAINNET_EXPLORER_URL=https://etherscan.io
